{
  "name": "zebrash-ts-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Bun workspace root for @zebrash/core, @zebrash/node, @zebrash/browser.",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "examples"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc -b packages/core/tsconfig.build.json packages/node/tsconfig.build.json packages/browser/tsconfig.build.json",
    "build:clean": "tsc -b packages/core/tsconfig.build.json packages/node/tsconfig.build.json packages/browser/tsconfig.build.json --clean",
    "typecheck": "tsc -b packages/core/tsconfig.build.json packages/node/tsconfig.build.json packages/browser/tsconfig.build.json",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "bun run build && vitest run --project core --project node",
    "test:watch": "vitest --project core",
    "test:browser": "bun run build && vitest run --project browser",
    "test:all": "bun run build && vitest run",
    "release": "bun run scripts/release.ts"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^1.0.0",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^24.0.0",
    "@vitest/browser": "^4.1.6",
    "@vitest/browser-playwright": "^4.1.6",
    "@zebrash/browser": "workspace:*",
    "@zebrash/core": "workspace:*",
    "@zebrash/node": "workspace:*",
    "oxfmt": "^0.50.0",
    "oxlint": "1.65.0",
    "playwright": "^1.60.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=24"
  }
}
